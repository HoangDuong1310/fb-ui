DATABASE_URL="mysql://root:@localhost:3306/fb_crawler"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES="30d"
PORT=3300
# Email admin đầu tiên — tài khoản đăng ký bằng email này sẽ tự được nâng lên role 'admin' + status 'approved' khi chạy migration
ADMIN_EMAIL="admin@example.com"
# AI defaults — CHỈ là fallback cho base URL + model khi người dùng để trống.
# KHÔNG có AI_API_KEY ở đây: mỗi người dùng tự cấu hình API key riêng trong phần
# Settings của web (lưu ở cột users.ai_api_key), không dùng chung secret server.
AI_API_BASE="https://danglamgiau.com/v1"
AI_MODEL="gpt-5.5"
